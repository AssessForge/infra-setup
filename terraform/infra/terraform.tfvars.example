# OCID do tenancy — OCI Console > Profile > Tenancy
tenancy_ocid = "ocid1.tenancy.oc1..EXAMPLE"

# OCID do compartment (pode ser o root compartment = tenancy_ocid)
compartment_ocid = "ocid1.compartment.oc1..EXAMPLE"

# Região OCI
region = "sa-saopaulo-1"

# Nome do cluster OKE
cluster_name = "assessforge-oke"

# Seu IP público em CIDR — descobrir via: curl -s ifconfig.me
bastion_allowed_cidr = "1.2.3.4/32"

# Emails para alertas do Cloud Guard e do alarme de billing (opcional — lista vazia nao cria subscription)
# Exemplo com multiplos destinatarios: ["ops@example.com", "sre@example.com"]
notification_emails = []

# GitHub OAuth App — GitHub > Settings > Developer Settings > OAuth Apps
# NUNCA commitar estes valores
github_oauth_client_id     = "Ov23liXXXXXXXXXXXX"
github_oauth_client_secret = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Alarme de billing — alerta por email quando qualquer custo OCI for maior que zero
enable_billing_alarm = false

# Email do service-account user ESO (workaround para bug IDCS matching-rule).
# OCI exige email no create-user; pode ser um endereco valido da sua org
# (não precisa ser monitorado; o user nao tem console access).
eso_user_email = "eso-sa@example.com"
